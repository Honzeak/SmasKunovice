<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:SmasKunovice.Avalonia.ViewModels"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="SmasKunovice.Avalonia.Views.ErrorWindow"
    x:DataType="viewmodels:ErrorWindowViewModel"
    Width="300"
    Height="150"
    WindowStartupLocation="CenterOwner"
    Title="ERROR!">
    <Grid
        RowDefinitions="Auto, *"
        ColumnDefinitions="Auto, *">
        <PathIcon
            Grid.Row="0"
            Grid.Column="0"
            Width="32"
            Height="32"
            Foreground="Orange"
            VerticalAlignment="Center"
            Data="M12,2L1,21H23L12,2M12,6L19.8,19H4.2L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" />
        <TextBlock
            Grid.Column="1"
            Grid.Row="0"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            TextAlignment="Center"
            Margin="0 10 0 0"
            TextWrapping="WrapWithOverflow"
            Text="{Binding ErrorMessage}">
        </TextBlock>

        <TextBlock
            Grid.Column="0"
            Grid.Row="1"
            Grid.ColumnSpan="2"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            TextAlignment="Center"
            Margin="0 10 0 0"
            TextWrapping="WrapWithOverflow"
            Text="{Binding ErrorDetails}">
        </TextBlock>
    </Grid>
</Window>