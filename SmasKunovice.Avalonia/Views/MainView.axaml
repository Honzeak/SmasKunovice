<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             xmlns:viewmodels="clr-namespace:SmasKunovice.Avalonia.ViewModels"
             x:DataType="viewmodels:MainViewViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SmasKunovice.Avalonia.Views.MainView">
    <Design.DataContext>
        <viewmodels:MainViewViewModel></viewmodels:MainViewViewModel>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,Auto">
        <mapsui:MapControl Grid.Row="0" Grid.Column="0" x:Name="MapControl" />
        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Path=Greeting}"></TextBox>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="20">
            <TextBlock Margin="0 5">Number of trajectory points:</TextBlock>
            <NumericUpDown Value="{Binding TrajectoryPointsCount}" Minimum="0" FormatString="0"/>
            <TextBlock Margin="0 5">Speed vector minute interval:</TextBlock>
            <NumericUpDown Value="{Binding SpeedVectorMinuteInterval}" Minimum="0" FormatString="0"/>
        </StackPanel>
    </Grid>

</UserControl>