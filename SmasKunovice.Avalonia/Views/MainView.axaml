<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SmasKunovice.Avalonia.Views.MainView">

    <Grid RowDefinitions="*,Auto">
        <mapsui:MapControl Grid.Row="0" x:Name="MapControl" />
        <TextBox Grid.Row="1" Text="Mrdka to je xd"></TextBox>
    </Grid>

</UserControl>